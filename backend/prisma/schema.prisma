generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  DEACTIVATED
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuizStatus {
  DRAFT
  PUBLISHED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  ARCHIVED
}

model Org {
  id                String             @id @default(uuid())
  name              String             @unique
  users             User[]
  teams             Team[]
  quizzes           Quiz[]
  assignments       Assignment[]
  attempts          Attempt[]
  phishingCampaigns PhishingCampaign[]
  smtpUser          String?
  smtpPassword      String?
  createdAt         DateTime           @default(now())
}

model User {
  id                 String              @id @default(uuid())
  org                Org                 @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId              String
  email              String              @unique
  passwordHash       String
  fullName           String
  role               Role
  status             UserStatus          @default(PENDING_VERIFICATION)
  emailVerifiedAt    DateTime?
  createdAt          DateTime            @default(now())
  emailVerifications EmailVerification[]
  refreshTokens      RefreshToken[]
  teams              TeamMember[]
  createdQuizzes     Quiz[]              @relation("QuizCreator")
  assignments        Assignment[]
  attempts           Attempt[]
  campaignTargets    CampaignTarget[]
  createdCampaigns   PhishingCampaign[]  @relation("CampaignCreator")
}

model RefreshToken {
  id        String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

model EmailVerification {
  id             String   @id @default(uuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  codeHash       String
  expiresAt      DateTime
  resendCount    Int      @default(0)
  failedAttempts Int      @default(0)
  lastSentAt     DateTime @default(now())
  createdAt      DateTime @default(now())
}

model Team {
  id        String       @id @default(uuid())
  org       Org          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  name      String
  members   TeamMember[]
  createdAt DateTime     @default(now())

  @@unique([orgId, name])
}

model TeamMember {
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@id([teamId, userId])
}

model Quiz {
  id           String       @id @default(uuid())
  org          Org          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId        String
  title        String
  description  String?
  status       QuizStatus   @default(DRAFT)
  difficulty   Difficulty
  tags         String[]
  passingScore Int?
  createdBy    User         @relation("QuizCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdById  String
  questions    Question[]
  assignments  Assignment[]
  attempts     Attempt[]
  createdAt    DateTime     @default(now())
}

model Question {
  id             String          @id @default(uuid())
  quiz           Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizId         String
  text           String
  explanation    String?
  order          Int             @default(0)
  choices        Choice[]
  attemptAnswers AttemptAnswer[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Choice {
  id             String          @id @default(uuid())
  question       Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId     String
  text           String
  isCorrect      Boolean         @default(false)
  attemptAnswers AttemptAnswer[]
  order          Int
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([questionId, order])
}

model Assignment {
  id        String           @id @default(uuid())
  org       Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  quiz      Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  dueAt     DateTime?
  status    AssignmentStatus @default(PENDING)
  attempts  Attempt[]
  createdAt DateTime         @default(now())
}

model Attempt {
  id           String          @id @default(uuid())
  assignment   Assignment      @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  org          Org             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId        String
  quiz         Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  startedAt    DateTime        @default(now())
  submittedAt  DateTime?
  scorePercent Float?
  correctCount Int?
  totalCount   Int?
  isPassed     Boolean?
  answers      AttemptAnswer[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model AttemptAnswer {
  id         String   @id @default(uuid())
  attempt    Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  attemptId  String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId String
  choice     Choice?  @relation(fields: [choiceId], references: [id])
  choiceId   String?
  isCorrect  Boolean

  @@unique([attemptId, questionId])
}

model PhishingCampaign {
  id           String           @id @default(uuid())
  org          Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId        String
  name         String
  description  String?
  status       CampaignStatus   @default(DRAFT)
  emailSubject String
  emailBody    String
  senderName   String
  senderEmail  String
  smtpUser     String?
  smtpPassword String?
  targets      CampaignTarget[]
  createdBy    User             @relation("CampaignCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdById  String
  scheduledAt  DateTime?
  sentAt       DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model CampaignTarget {
  id          String           @id @default(uuid())
  campaign    PhishingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId  String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  token       String           @unique
  emailSentAt DateTime?
  clickedAt   DateTime?
  createdAt   DateTime         @default(now())

  @@unique([campaignId, userId])
}
